{
	"name": "json_data_flow",
	"properties": {
		"folder": {
			"name": "Healtcare_project_dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "bulk_json_to_csv_sink",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "age"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "flatten1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "filter2"
				},
				{
					"name": "select2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "join1"
				},
				{
					"name": "select3"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source1",
				"filter1 select(mapColumn(",
				"          resourceType = entry.resource.resourceType,",
				"          id = entry.resource.id,",
				"          gender = entry.resource.gender,",
				"          Birthdate = entry.resource.birthDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(age = floor(monthsBetween(currentDate(), Birthdate) / 12)) ~> age",
				"age derive(age_bend = case(     age < 18, '0-17',     age < 35, '18-34',     age < 50, '35-49',     age < 65, '50-64',     '65+' )) ~> derivedColumn2",
				"source1 foldDown(unroll(entry),",
				"     mapColumn(",
				"          entry",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flatten1",
				"flatten1 filter(entry.resource.resourceType=='Patient') ~> filter1",
				"flatten1 filter(entry.resource.resourceType=='Claim') ~> filter2",
				"filter2 select(mapColumn(",
				"          patient_id = entry.resource.patient.reference,",
				"          insurar = entry.resource.insurance[1].coverage.display,",
				"          claim_date = entry.resource.created",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 derive(patient_id = replace(patient_id,'urn:uuid:','')) ~> derivedColumn3",
				"derivedColumn3 derive(claim_date = toDate(claim_date, 'yyyy-MM-dd')) ~> derivedColumn4",
				"derivedColumn4 aggregate(groupBy(patient_id),",
				"     claim_date = max(claim_date),",
				"          insurar = first(insurar)) ~> aggregate1",
				"aggregate1 derive(insurance_tier = case( insurar == 'Humana', 'Premium',     insurar == 'UnitedHealthcare', 'Premium',     insurar == 'Aetna', 'Premium',     insurar == 'Medicare', 'Government',     insurar == 'Medicaid', 'Government',     isNull(insurar), 'Unknown',     'Standard' )) ~> derivedColumn5",
				"derivedColumn5, derivedColumn2 join(patient_id == id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 select(mapColumn(",
				"          patient_id,",
				"          claim_date,",
				"          insurar,",
				"          insurance_tier,",
				"          resourceType,",
				"          id,",
				"          gender,",
				"          birthDate = Birthdate,",
				"          age,",
				"          age_bend",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}